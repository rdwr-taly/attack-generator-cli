{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://radware.example.com/schemas/attackmap.schema.json",
  "title": "AttackMap v1",
  "type": "object",
  "required": ["version", "name", "target", "safety", "attacks"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "target": {
      "type": "object",
      "required": ["base_url"],
      "properties": {
        "base_url": { "type": "string", "format": "uri" },
        "xff_header": { "type": "string" }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": ["allowlist"],
      "properties": {
        "allowlist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "global_rps_cap": { "type": "integer", "minimum": 1 },
        "stop_on_target_mismatch": { "type": "boolean" },
        "banner": { "type": "string" }
      },
      "additionalProperties": false
    },
    "presets": {
      "type": "object",
      "properties": {
        "ua_group": { "type": "string" },
        "headers": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "values"],
            "properties": {
              "type": { "const": "list" },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "min", "max"],
            "properties": {
              "type": { "const": "int" },
              "min": { "type": "integer" },
              "max": { "type": "integer" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "auth": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["basic", "form", "bearer"]
        },
        "path": { "type": "string" },
        "method": { "type": "string" },
        "credentials": {
          "type": "object",
          "required": ["username", "password"],
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          },
          "additionalProperties": false
        },
        "json_path": { "type": "string" },
        "store": {
          "type": "object",
          "properties": {
            "header": { "type": "boolean" },
            "cookie": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "attacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "traffic_type", "category", "method", "path"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "traffic_type": { "type": "string", "enum": ["web", "api"] },
          "category": { "type": "string" },
          "method": { "type": "string" },
          "path": { "type": "string" },
          "headers": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            ]
          },
          "body_type": {
            "type": "string",
            "enum": ["json", "form", "raw"]
          },
          "body": {}
        },
        "additionalProperties": false
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "select"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "select": {
            "type": "object",
            "properties": {
              "by_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "by_category": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "ip_pool": { "type": "string" },
          "ua_group": { "type": "string" },
          "headers": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            ]
          },
          "rate": {
            "type": "object",
            "properties": {
              "qps": { "type": "integer", "minimum": 1 },
              "duration_sec": { "type": "integer", "minimum": 1 }
            },
            "required": ["qps"],
            "additionalProperties": false
          },
          "jitter_ms": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "additionalProperties": false
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "think_time_ms": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "concurrency": { "type": "integer", "minimum": 1 },
        "cookie_jar": { "type": "string" },
        "session_reuse": { "type": "boolean" },
        "retry": {
          "type": "object",
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 0 },
            "backoff_seconds": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
